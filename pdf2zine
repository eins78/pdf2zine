#!/bin/bash
set -eu

usage() {
    echo "Usage: $0 [--keep-cover] [--keep-format] <input.pdf> [-- <bookletimposer args>...]"
    echo "  --keep-cover   Do not move the first page to the end before imposing"
    echo "  --keep-format  Let bookletimposer pick the output size (default: force A4)"
    echo "  --             Pass remaining args through to bookletimposer"
    exit 1
}

KEEP_COVER=0
KEEP_FORMAT=0
INPUT=""
PASSTHROUGH=()
SEEN_DASHDASH=0
for arg in "$@"; do
    if [ "$SEEN_DASHDASH" -eq 1 ]; then
        PASSTHROUGH+=("$arg")
        continue
    fi
    case "$arg" in
        --) SEEN_DASHDASH=1 ;;
        --keep-cover) KEEP_COVER=1 ;;
        --keep-format) KEEP_FORMAT=1 ;;
        -h|--help) usage ;;
        -*) echo "Unknown option: $arg"; usage ;;
        *) INPUT="$arg" ;;
    esac
done

# No input file: forward pass-through args directly to bookletimposer
# (e.g. `pdf2zine -- -h` shows bookletimposer help)
if [ -z "$INPUT" ]; then
    if [ "${#PASSTHROUGH[@]}" -gt 0 ]; then
        exec docker run --rm -v "$(pwd):/data" -w /data -u "$(id -u):$(id -g)" eins78/bookletimposer "${PASSTHROUGH[@]}"
    fi
    usage
fi

# Check if input file exists
if [ ! -f "$INPUT" ]; then
    echo "Error: Input file '$INPUT' does not exist."
    exit 1
fi

alias qpdf='docker run --rm -v "$(pwd):/data" -w /data -u "$(id -u):$(id -g)" eins78/qpdf'

TMPDIR="$(mktemp -d)"
echo "Using temporary directory: $TMPDIR"

INPUT_DIR="$(realpath "$(dirname "$INPUT")")"
FILENAME="$(basename "$INPUT" .pdf)"
OUTPUT_FILE="${INPUT_DIR}/${FILENAME}_booklet.pdf"
INPUT_FILE="input.pdf"

cp "$INPUT" "${TMPDIR}/${INPUT_FILE}"
cd "$TMPDIR"

NPAGES=$(qpdf --show-npages "$INPUT_FILE")
echo "Number of pages: $NPAGES"

if [ "$KEEP_COVER" -eq 1 ]; then
    echo "Keeping cover page in place (--keep-cover)"
    BOOKLET_INPUT="$INPUT_FILE"
else
    echo "Running qpdf command to move cover page to the end..."
    qpdf "$INPUT_FILE" --pages "$INPUT_FILE" 2-z "$INPUT_FILE" 1 -- "cover_moved.pdf"
    BOOKLET_INPUT="cover_moved.pdf"
fi

FORMAT_ARGS=()
if [ "$KEEP_FORMAT" -eq 0 ]; then
    FORMAT_ARGS+=(--format=A4)
fi

echo "making booklet"
docker run --rm -v "${TMPDIR}:/data" -w /data -u "$(id -u):$(id -g)" eins78/bookletimposer --no-gui --booklet "${FORMAT_ARGS[@]}" "${PASSTHROUGH[@]}" "$BOOKLET_INPUT" --output="booklet.pdf"

mv "booklet.pdf" "${OUTPUT_FILE}"
echo "Done! Booklet created at: ${OUTPUT_FILE}"

rm -rf "$TMPDIR"

